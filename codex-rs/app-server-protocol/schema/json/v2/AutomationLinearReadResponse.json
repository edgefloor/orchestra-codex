{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "AutomationIssue": {
      "properties": {
        "blockedBy": {
          "items": {
            "$ref": "#/definitions/AutomationIssueBlocker"
          },
          "type": "array"
        },
        "branchName": {
          "type": [
            "string",
            "null"
          ]
        },
        "createdAt": {
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "identifier": {
          "type": "string"
        },
        "labels": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "priority": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "state": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "updatedAt": {
          "type": [
            "string",
            "null"
          ]
        },
        "url": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "blockedBy",
        "id",
        "identifier",
        "labels",
        "state",
        "title"
      ],
      "type": "object"
    },
    "AutomationIssueBlocker": {
      "properties": {
        "id": {
          "type": [
            "string",
            "null"
          ]
        },
        "identifier": {
          "type": [
            "string",
            "null"
          ]
        },
        "state": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "AutomationLinearReadStatus": {
      "enum": [
        "ready",
        "skipped"
      ],
      "type": "string"
    },
    "OrchestraBoundedText": {
      "properties": {
        "text": {
          "type": "string"
        },
        "truncated": {
          "type": "boolean"
        }
      },
      "required": [
        "text",
        "truncated"
      ],
      "type": "object"
    }
  },
  "properties": {
    "endCursor": {
      "type": [
        "string",
        "null"
      ]
    },
    "hasNextPage": {
      "type": "boolean"
    },
    "issues": {
      "items": {
        "$ref": "#/definitions/AutomationIssue"
      },
      "type": "array"
    },
    "nextAction": {
      "$ref": "#/definitions/OrchestraBoundedText"
    },
    "status": {
      "$ref": "#/definitions/AutomationLinearReadStatus"
    }
  },
  "required": [
    "hasNextPage",
    "issues",
    "nextAction",
    "status"
  ],
  "title": "AutomationLinearReadResponse",
  "type": "object"
}
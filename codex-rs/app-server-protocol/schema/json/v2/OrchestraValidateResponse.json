{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "OrchestraStepKind": {
      "enum": [
        "agent",
        "check",
        "approval"
      ],
      "type": "string"
    },
    "OrchestraWorkflowPlan": {
      "properties": {
        "description": {
          "type": "string"
        },
        "maxParallel": {
          "format": "uint32",
          "minimum": 0.0,
          "type": "integer"
        },
        "name": {
          "type": "string"
        },
        "steps": {
          "items": {
            "$ref": "#/definitions/OrchestraWorkflowStep"
          },
          "type": "array"
        }
      },
      "required": [
        "description",
        "maxParallel",
        "name",
        "steps"
      ],
      "type": "object"
    },
    "OrchestraWorkflowStep": {
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/definitions/OrchestraStepKind"
        },
        "maxAttempts": {
          "format": "uint32",
          "minimum": 0.0,
          "type": "integer"
        },
        "needs": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "id",
        "kind",
        "maxAttempts",
        "needs"
      ],
      "type": "object"
    }
  },
  "properties": {
    "plan": {
      "$ref": "#/definitions/OrchestraWorkflowPlan"
    },
    "valid": {
      "type": "boolean"
    }
  },
  "required": [
    "plan",
    "valid"
  ],
  "title": "OrchestraValidateResponse",
  "type": "object"
}
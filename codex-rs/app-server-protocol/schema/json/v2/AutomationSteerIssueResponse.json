        "initiatorThreadId": {
          "type": "string"
        },
        "inputPreview": {
          "type": "string"
        },
        "inputSha256": {
          "type": "string"
        },
        "providerReceipt": {
          "type": [
            "string",
            "null"
          ]
        },
        "sequence": {
          "format": "uint32",
          "minimum": 0.0,
          "type": "integer"
